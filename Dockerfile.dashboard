FROM dhi.io/golang:1.26.4-alpine3.24-dev@sha256:e48a91483983467f426cae8656aa16be252c6f2e290125e10db01259352a54ca AS builder

ARG TARGETOS=linux
ARG TARGETARCH=amd64

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY cmd/dashboard ./cmd/dashboard
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -trimpath -ldflags="-s -w" -o /out/netzbremse-dashboard ./cmd/dashboard

FROM dhi.io/alpine-base:3.24@sha256:f5156164366417ee97c8daca5ec9348227d5100e4eadb822a19a3793ab3e7976

LABEL org.opencontainers.image.source="https://git.m0sh1.cc/m0sh1/netzbremse" \
  org.opencontainers.image.url="https://git.m0sh1.cc/m0sh1/netzbremse" \
  org.opencontainers.image.title="netzbremse-dashboard" \
  org.opencontainers.image.description="Netzbremse dashboard backed by PostgreSQL instead of shared filesystem state"

WORKDIR /app
COPY --from=builder /out/netzbremse-dashboard /usr/local/bin/netzbremse-dashboard

USER nonroot
EXPOSE 8501
ENTRYPOINT ["/usr/local/bin/netzbremse-dashboard"]
